# FluxGraph Configuration Example
# Copy this to .env and fill in the values

# App
FLUXGRAPH_APP_NAME=fluxgraph
FLUXGRAPH_APP_ENV=development
FLUXGRAPH_APP_PORT=8080
FLUXGRAPH_APP_A2A_SECRET=your-secret-key-here

# Storage
FLUXGRAPH_STORAGE_REDIS_URL=redis://localhost:6379/0
FLUXGRAPH_STORAGE_REDIS_POOL_SIZE=10
FLUXGRAPH_STORAGE_REDIS_TTL=24h
FLUXGRAPH_STORAGE_POSTGRES_URL=postgres://user:pass@localhost:5432/fluxgraph?sslmode=disable
FLUXGRAPH_STORAGE_POSTGRES_MAX_CONNS=20

# LLM Providers
FLUXGRAPH_LLM_OPENAI_API_KEY=sk-...
FLUXGRAPH_LLM_OPENAI_MODEL=gpt-4o
FLUXGRAPH_LLM_ANTHROPIC_API_KEY=x-api-key-...
FLUXGRAPH_LLM_ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Observability
FLUXGRAPH_OBSERVABILITY_OTEL_ENDPOINT=localhost:4318
FLUXGRAPH_OBSERVABILITY_PROMETHEUS_PORT=9090
